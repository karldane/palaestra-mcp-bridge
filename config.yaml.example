# mcp-bridge configuration
# Copy to config.yaml and adjust for your environment.

server:
  port: "8080"
  logLevel: info    # debug | info | warn | error

backends:
  # Example: filesystem backend
  # filesystem:
  #   command: "npx -y @modelcontextprotocol/server-filesystem /path/to/allowed"
  #   poolSize: 2
  #   toolPrefix: "filesystem"
  #   env: {}
  #   secrets: []

  # Example: fetch backend (read-only HTTP requests)
  # fetch:
  #   command: "npx -y @modelcontextprotocol/server-fetch"
  #   poolSize: 2
  #   toolPrefix: "fetch"
  #   env: {}
  #   secrets: []
